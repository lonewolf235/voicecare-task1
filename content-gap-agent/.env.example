# Content Gap Agent — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# =============================================================================
# REQUIRED — API Keys
# =============================================================================

# OpenAI API key (for embeddings + GPT completions)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Firecrawl API key (for web scraping)
# Get yours at: https://www.firecrawl.dev/
FIRECRAWL_API_KEY=fc-your-firecrawl-api-key-here

# =============================================================================
# OPTIONAL — Slack Integration
# =============================================================================

# Slack Incoming Webhook URL (leave empty to disable Slack notifications)
# Create one at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Slack channel to post to (must include the # prefix)
SLACK_CHANNEL=#content-strategy

# =============================================================================
# OPTIONAL — Agent Behavior
# =============================================================================

# Your company name (used in Slack messages and reports)
COMPANY_NAME=My Company

# GPT model to use for gap analysis and script generation
# Options: gpt-4o, gpt-4o-mini, gpt-4-turbo
OPENAI_GPT_MODEL=gpt-4o

# Target audience description for video scripts
TARGET_AUDIENCE=B2B decision-makers and practitioners interested in technology and AI automation

# Directory where CSV and JSON reports are saved (relative to project root)
REPORTS_DIR=reports

# =============================================================================
# OPTIONAL — Scheduler Settings
# =============================================================================

# Day of the week to run the pipeline (lowercase)
# Options: monday, tuesday, wednesday, thursday, friday, saturday, sunday
SCHEDULE_DAY=monday

# Time to run the pipeline (24-hour format HH:MM, local time)
SCHEDULE_TIME=08:00
