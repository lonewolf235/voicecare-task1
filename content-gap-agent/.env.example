# Content Gap Agent — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# =============================================================================
# REQUIRED — Core API Keys
# =============================================================================

# OpenAI API key (embeddings via text-embedding-3-small + GPT-4o completions)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Firecrawl API key (web crawling via Firecrawl)
# Get yours at: https://www.firecrawl.dev/
FIRECRAWL_API_KEY=fc-your-firecrawl-api-key-here

# =============================================================================
# RECOMMENDED — Semrush (search volume data for gap ranking)
# =============================================================================

# Semrush API key (used by rank_gaps() to fetch monthly search volume per topic)
# Without this key, search_volume defaults to 0 and ranking uses novelty + viral signals only.
# Get yours at: https://www.semrush.com/api-documentation/
SEMRUSH_API_KEY=your-semrush-api-key-here

# Semrush database/market (us, uk, ca, au, etc.)
SEMRUSH_DATABASE=us

# =============================================================================
# OPTIONAL — Slack Integration
# =============================================================================

# Slack Incoming Webhook URL (leave empty to disable Slack notifications)
# Create one at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Slack channel to post to (must include the # prefix)
SLACK_CHANNEL=#content-strategy

# =============================================================================
# OPTIONAL — Agent Behavior
# =============================================================================

# Your company name (used in Slack messages and reports)
COMPANY_NAME=Voicecare.ai

# GPT model for gap analysis and script generation
# Options: gpt-4o, gpt-4o-mini, gpt-4-turbo
OPENAI_GPT_MODEL=gpt-4o

# Target audience for video scripts (overrides company_context.target_customer)
TARGET_AUDIENCE=Healthcare providers, clinic managers, and digital health teams

# Directory where CSV/JSON reports are saved (relative to project root)
REPORTS_DIR=reports

# Directory where weekly script outputs are saved
OUTPUTS_DIR=outputs

# =============================================================================
# OPTIONAL — Scheduler Settings (APScheduler)
# =============================================================================

# Day of the week to run the pipeline (lowercase, used by scheduler.py)
# Options: monday, tuesday, wednesday, thursday, friday, saturday, sunday
SCHEDULE_DAY=monday

# Time to run in HH:MM local time format
SCHEDULE_TIME=08:00
