{
  "version": 2,
  "comment": "Vercel serves only the static frontend. The Python backend runs on Railway/Render.",
  "builds": [
    {
      "src": "templates/index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/templates/index.html"
    }
  ]
}
